graph TB
    %% Input and Initialization
    subgraph "Input & Setup"
        A[Input Data<br/>X: (channels, timesteps)] --> B[Model & Background Data]
        B --> C[Sensor Groups<br/>RF, HAM, TA, GAS]
        C --> D[Initialize Components]
    end

    %% Component Initialization
    subgraph "Core Components"
        D --> E[Shapley Channel Ranker]
        D --> F[Adaptive Multi-Objective Loss]
        D --> G[Adaptive Weight Manager]
        D --> H[Group Gate Controller]
    end

    %% Shapley Analysis Phase
    subgraph "Phase 1: Group Importance Analysis"
        E --> I[Compute Shapley Values<br/>per Channel]
        I --> J[Aggregate to Group Level<br/>Mean Importance Scores]
        J --> K[Rank & Select Top ~50%<br/>Most Influential Groups]
    end

    %% Optimization Setup
    subgraph "Phase 2: Optimization Setup"
        K --> L[Create Group Masks<br/>Binary masks per group]
        L --> M[Initialize Learnable Components]
        M --> N[Restricted Channel Mask<br/>Only selected groups]
        M --> O[Group Gates<br/>Learnable per-group weights]
        M --> P[Find Nearest Unlike Neighbor<br/>From target class]
    end

    %% Adaptive Optimization Loop
    subgraph "Phase 3: Adaptive Multi-Objective Optimization"
        N --> Q[Apply Sigmoid Activation]
        O --> R[Apply Group Gating]
        Q --> S[Expand to Full Channels]
        R --> S
        S --> T[Combined Mask = Channel × Group Gates]
        
        T --> U[Generate Counterfactual<br/>X_cf = X × (1-mask) + neighbor × mask]
        U --> V[Forward Pass<br/>Model(X_cf)]
        
        V --> W[Multi-Objective Loss Components]
        W --> W1[Target Loss<br/>1 - P(target_class)]
        W --> W2[Sparsity Loss<br/>L1(mask)]
        W --> W3[Smoothness Loss<br/>Temporal coherence]
        W --> W4[Group Sparsity Loss<br/>Active groups]
        W --> W5[Group Gate Loss<br/>L1 regularization]
        
        W1 --> X[Adaptive Weight Update]
        W2 --> X
        W3 --> X
        W4 --> X
        W5 --> X
        
        X --> Y{Target Achieved?<br/>P(target) ≥ threshold}
        Y -->|Yes| Z1[↑ Sparsity Weights<br/>↓ Target Weight]
        Y -->|No| Z2[↑ Target Weight<br/>↓ Sparsity Weights]
        
        Z1 --> AA[Weighted Total Loss]
        Z2 --> AA
        AA --> BB[Backpropagation<br/>Update mask & gates]
        BB --> CC{Convergence?}
        CC -->|No| Q
        CC -->|Yes| DD[Extract Results]
    end

    %% Dynamic Group Removal
    subgraph "Dynamic Group Removal"
        R --> GR1[Monitor Group Gates]
        GR1 --> GR2{Gate < 0.5?}
        GR2 -->|Yes| GR3[Suppress Group<br/>Zero activation]
        GR2 -->|No| GR4[Keep Group Active]
        GR3 --> GR5[Update Active Groups List]
        GR4 --> GR5
    end

    %% Results and Evaluation
    subgraph "Phase 4: Results & Evaluation"
        DD --> EE[Extract Selected Channels<br/>mask ≥ threshold]
        DD --> FF[Evaluate Counterfactual<br/>Validity, Confidence]
        DD --> GG[Generate Explanation Summary<br/>Group usage, optimization trace]
        
        EE --> HH[Return Results]
        FF --> HH
        GG --> HH
        
        HH --> II[Binary Mask<br/>Counterfactual Data<br/>Selected Channels<br/>Metrics]
    end

    %% Weight Adaptation Details
    subgraph "Adaptive Weight Management"
        G --> WM1[Monitor Target Probability]
        WM1 --> WM2{P(target) ≥ 0.8?}
        WM2 -->|Yes| WM3[Focus on Sparsity<br/>λ_sparsity ↑, λ_target ↓]
        WM2 -->|No| WM4[Focus on Target<br/>λ_target ↑, λ_sparsity ↓]
        WM3 --> WM5[Update Weight History]
        WM4 --> WM5
    end

    %% Loss Function Architecture
    subgraph "Multi-Objective Loss Architecture"
        F --> LF1[Target Loss: 1 - softmax[target]]
        F --> LF2[Sparsity Loss: mean(mask)]
        F --> LF3[Smoothness Loss: temporal_diff²]
        F --> LF4[Group Sparsity: mean(group_activations)]
        F --> LF5[Group Gate Regularization]
    end

    %% Styling
    classDef inputNode fill:#e1f5fe
    classDef componentNode fill:#f3e5f5
    classDef processNode fill:#e8f5e8
    classDef decisionNode fill:#fff3e0
    classDef outputNode fill:#fce4ec

    class A,B,C inputNode
    class E,F,G,H componentNode
    class I,J,K,L,M,N,O,P,Q,R,S,T,U,V processNode
    class Y,CC,GR2,WM2 decisionNode
    class II,HH outputNode